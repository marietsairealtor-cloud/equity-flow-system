{
  "version": 1,
  "lanes": [
    {
      "lane": "docs_only",
      "include_globs": [
        "docs/**"
      ],
      "exclude_globs": [
        "docs/truth/**",
        "docs/artifacts/**",
        "docs/governance/**"
      ],
      "required_checks": [
        "CI / ci-semantic-contract",
        "CI / ci-topology-audit",
        "CI / env-sanity",
        "CI / foundation-invariants",
        "CI / proof-commit-binding",
        "CI / proof-manifest",
        "CI / stop-the-line",
        "CI / test",
        "CI / toolchain-contract",
        "CI / truth-sync-enforced",
        "CI / waiver-debt-enforcement"
      ]
    },
    {
      "lane": "governance",
      "include_globs": [
        ".github/workflows/**",
        "scripts/**",
        "docs/truth/**",
        "docs/artifacts/**",
        "docs/governance/**",
        ".gitattributes",
        ".editorconfig",
        "package.json",
        "package-lock.json"
      ],
      "exclude_globs": [],
      "required_checks": [
        "CI / ci-semantic-contract",
        "CI / ci-topology-audit",
        "CI / env-sanity",
        "CI / foundation-invariants",
        "CI / proof-commit-binding",
        "CI / proof-manifest",
        "CI / stop-the-line",
        "CI / test",
        "CI / toolchain-contract",
        "CI / truth-sync-enforced",
        "CI / waiver-debt-enforcement"
      ]
    },
    {
      "lane": "runtime",
      "include_globs": [
        "supabase/**",
        "generated/**"
      ],
      "exclude_globs": [],
      "required_checks": [
        "CI / ci-semantic-contract",
        "CI / ci-topology-audit",
        "CI / env-sanity",
        "CI / foundation-invariants",
        "CI / proof-commit-binding",
        "CI / proof-manifest",
        "CI / stop-the-line",
        "CI / test",
        "CI / toolchain-contract",
        "CI / truth-sync-enforced",
        "CI / waiver-debt-enforcement"
      ]
    },
    {
      "lane": "surface-truth",
      "include_globs": [
        "docs/truth/surface_truth.json",
        "scripts/capture_surface_truth.mjs",
        "scripts/ci_surface_truth.mjs"
      ],
      "exclude_globs": [],
      "required_checks": [
        "CI / ci-semantic-contract",
        "CI / ci-topology-audit",
        "CI / env-sanity",
        "CI / foundation-invariants",
        "CI / proof-commit-binding",
        "CI / proof-manifest",
        "CI / stop-the-line",
        "CI / test",
        "CI / toolchain-contract",
        "CI / truth-sync-enforced",
        "CI / waiver-debt-enforcement"
      ]
    },
    {
      "lane": "deploy",
      "include_globs": [
        "supabase/migrations/**"
      ],
      "exclude_globs": [],
      "required_checks": [
        "CI / ci-semantic-contract",
        "CI / ci-topology-audit",
        "CI / env-sanity",
        "CI / foundation-invariants",
        "CI / proof-commit-binding",
        "CI / proof-manifest",
        "CI / stop-the-line",
        "CI / test",
        "CI / toolchain-contract",
        "CI / truth-sync-enforced",
        "CI / waiver-debt-enforcement"
      ],
      "notes": "Deploy lane: reload must occur after migration apply. Reload evidence required in proof logs."
    },
    {
      "lane": "release",
      "include_globs": [
        "docs/proofs/**"
      ],
      "exclude_globs": [],
      "required_checks": [
        "CI / ci-semantic-contract",
        "CI / ci-topology-audit",
        "CI / env-sanity",
        "CI / foundation-invariants",
        "CI / proof-commit-binding",
        "CI / proof-manifest",
        "CI / stop-the-line",
        "CI / test",
        "CI / toolchain-contract",
        "CI / truth-sync-enforced",
        "CI / waiver-debt-enforcement"
      ],
      "notes": "Release lane: ci_surface_invariants.mjs must pass after reload. Surface must match expected_surface.json."
    }
  ]
}
